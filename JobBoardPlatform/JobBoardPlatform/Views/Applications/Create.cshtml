@model JobBoardPlatform.Models.Application

@{
    ViewData["Title"] = "Apply for Job";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0">
                <div class="card-header bg-success text-white py-3">
                    <h3 class="card-title mb-0 text-center">
                        <i class="bi bi-send-fill"></i> Submit Your Application
                    </h3>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                       
                        <input type="hidden" asp-for="JobPostingId" />
                       

                        <div class="mb-3">
                            <label asp-for="CandidateName" class="form-label fw-bold">Full Name</label>
                            <input asp-for="CandidateName" class="form-control form-control-lg" placeholder="John Doe" />
                            <span asp-validation-for="CandidateName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="MotivationLetter" class="form-label fw-bold">Motivation Letter / Short Intro</label>
                            <textarea asp-for="MotivationLetter" class="form-control" rows="6" 
                                      placeholder="Briefly explain why you're a great fit for this position..."></textarea>
                            <span asp-validation-for="MotivationLetter" class="text-danger"></span>
                        </div>

                        <hr />

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success btn-lg shadow-sm">
                                <b>Send Application</b>
                            </button>
                            <a asp-controller="JobPostings" asp-action="Index" class="btn btn-link text-secondary">
                                Cancel and return to jobs
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}