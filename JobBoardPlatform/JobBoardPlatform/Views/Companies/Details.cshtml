@model JobBoardPlatform.Models.Company

@{
    ViewData["Title"] = "Company Details";
}

<div class="container mt-4">
    <div class="card shadow border-0">
        <div class="card-header bg-info text-white py-3">
            <h2 class="mb-0">@Model.Name</h2>
        </div>
        <div class="card-body p-4">
            <h5 class="text-muted fw-bold">About the Company:</h5>
            <p class="lead text-dark">@Model.Description</p>
            
            <hr class="my-4" />
            
            <h4><i class="bi bi-briefcase"></i> Active Job Openings:</h4>
            @if (Model.JobPostings != null && Model.JobPostings.Any())
            {
                <div class="list-group mt-3">
                    @foreach (var job in Model.JobPostings)
                    {
                        <a asp-controller="JobPostings" asp-action="Details" asp-route-id="@job.Id" 
                           class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                            <span class="fw-bold text-primary">@job.Title</span>
                            <span class="badge bg-secondary rounded-pill">View Job</span>
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-light border mt-3">
                    No active job openings at the moment for this company.
                </div>
            }
        </div>
        <div class="card-footer bg-light d-flex justify-content-between">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Back to List
            </a>
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit Company Info</a>
            }
        </div>
    </div>
</div>