@model JobBoardPlatform.Models.JobPosting

@{
    ViewData["Title"] = "Edit Job Posting";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-primary text-white py-3 text-center">
                    <h3 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2"></i>Update Job Details</h3>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="form-floating mb-3">
                            <input asp-for="Title" class="form-control shadow-sm" placeholder="Job Title" />
                            <label asp-for="Title">Job Title</label>
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <textarea asp-for="Description" class="form-control shadow-sm" style="height: 120px" placeholder="Description"></textarea>
                            <label asp-for="Description">Job Description</label>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Location" class="form-control shadow-sm" placeholder="Location" />
                                    <label asp-for="Location">Location</label>
                                    <span asp-validation-for="Location" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Salary" class="form-control shadow-sm" placeholder="Salary" />
                                    <label asp-for="Salary">Salary</label>
                                    <span asp-validation-for="Salary" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-muted small ms-1">Assign to Company</label>
                            <select asp-for="CompanyId" class="form-select form-select-lg shadow-sm" asp-items="ViewBag.CompanyId"></select>
                            <span asp-validation-for="CompanyId" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2 pt-2">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill shadow">
                                <i class="bi bi-save me-2"></i>Save Changes
                            </button>
                            <a asp-action="Index" class="btn btn-link text-decoration-none text-muted mt-2">Cancel and go back</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}