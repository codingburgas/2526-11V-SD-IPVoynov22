@model IEnumerable<JobBoardPlatform.Models.JobPosting>
@using System.Security.Claims
@{
    ViewData["Title"] = "Job Openings";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <h2 class="fw-bold text-dark"><i class="bi bi-list-stars text-primary me-2"></i>Job Opportunities</h2>
    @if (User.IsInRole("Admin") || User.IsInRole("Employer"))
    {
        <a asp-action="Create" class="btn btn-primary rounded-pill shadow-sm px-4">
            <i class="bi bi-plus-lg me-1"></i> Post a Job
        </a>
    }
</div>

<div class="card border-0 shadow-sm overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4 border-0 py-3">Position</th>
                    <th class="border-0 py-3">Details</th>
                    <th class="border-0 py-3">Salary</th>
                    <th class="border-0 py-3">Company</th>
                    <th class="text-center border-0 py-3">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model) {
                <tr>
                    <td class="ps-4 py-4">
                        <div class="fw-bold text-primary fs-5">@item.Title</div>
                        <span class="text-muted small"><i class="bi bi-calendar3"></i> @item.CreatedAt.ToString("MMM dd, yyyy")</span>
                    </td>
                    <td>
                        <span class="badge bg-light text-secondary border px-3 py-2 rounded-pill">📍 @item.Location</span>
                    </td>
                    <td>
                        <div class="fw-bold text-success fs-5">@item.Salary.ToString("C0")</div>
                    </td>
                    <td>
                        <div class="text-dark fw-semibold">@item.Company.Name</div>
                    </td>
                    <td class="text-center pe-4">
                        <div class="d-flex justify-content-end align-items-center gap-2">
                            <a asp-controller="Applications" asp-action="Create" asp-route-jobPostingId="@item.Id" 
                               class="btn btn-success px-4 rounded-pill shadow-sm">Apply</a>
                            
                            <div class="dropdown">
                                <button class="btn btn-light btn-sm border rounded-circle" data-bs-toggle="dropdown"><i class="bi bi-three-dots-vertical"></i></button>
                                <ul class="dropdown-menu shadow border-0">
                                    <li><a asp-action="Details" asp-route-id="@item.Id" class="dropdown-item"><i class="bi bi-info-circle me-2"></i>Details</a></li>
                                    @if (User.IsInRole("Admin") || (User.IsInRole("Employer") && item.PublisherId == currentUserId))
                                    {
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a asp-action="Edit" asp-route-id="@item.Id" class="dropdown-item text-warning"><i class="bi bi-pencil me-2"></i>Edit</a></li>
                                        <li><a asp-action="Delete" asp-route-id="@item.Id" class="dropdown-item text-danger"><i class="bi bi-trash me-2"></i>Delete</a></li>
                                    }
                                </ul>
                            </div>
                        </div>
                    </td>
                </tr>
                }
            </tbody>
        </table>
    </div>
</div>