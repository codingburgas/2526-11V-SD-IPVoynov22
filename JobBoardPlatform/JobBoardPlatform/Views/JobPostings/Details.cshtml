@model JobBoardPlatform.Models.JobPosting
@using System.Security.Claims

@{
    ViewData["Title"] = "Job Details";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-9">
            <div class="card shadow-lg border-0 overflow-hidden">
               
                <div class="card-header bg-dark text-white p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h1 class="display-6 fw-bold mb-1">@Model.Title</h1>
                            <p class="mb-0 opacity-75"><i class="bi bi-building me-2"></i>@Model.Company?.Name</p>
                        </div>
                        <span class="badge bg-primary px-3 py-2">Full-time</span>
                    </div>
                </div>

                <div class="card-body p-4 p-lg-5">
                    @* Бърза информация - икони *@
                    <div class="row mb-5 text-center g-3">
                        <div class="col-6 col-md-3">
                            <div class="p-3 border rounded-3 bg-light">
                                <i class="bi bi-geo-alt text-danger h3 d-block mb-2"></i>
                                <span class="fw-bold d-block">Location</span>
                                <span class="text-muted small">@Model.Location</span>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="p-3 border rounded-3 bg-light">
                                <i class="bi bi-cash-stack text-success h3 d-block mb-2"></i>
                                <span class="fw-bold d-block">Salary</span>
                                <span class="text-muted small">@Model.Salary.ToString("C0")</span>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="p-3 border rounded-3 bg-light">
                                <i class="bi bi-calendar-event text-primary h3 d-block mb-2"></i>
                                <span class="fw-bold d-block">Posted On</span>
                                <span class="text-muted small">@Model.CreatedAt.ToString("dd.MM.yyyy")</span>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="p-3 border rounded-3 bg-light">
                                <i class="bi bi-person-badge text-info h3 d-block mb-2"></i>
                                <span class="fw-bold d-block">Publisher</span>
                                <span class="text-muted small">@Model.Company?.Name</span>
                            </div>
                        </div>
                    </div>

                   
                    <div class="job-description mb-5">
                        <h4 class="fw-bold mb-3 border-bottom pb-2">Job Description</h4>
                        <div class="text-dark fs-5" style="white-space: pre-line; line-height: 1.8;">
                            @Model.Description
                        </div>
                    </div>

                   
                    <div class="d-flex flex-wrap gap-3 mt-5">
                      
                        <a asp-controller="Applications" asp-action="Create" asp-route-jobPostingId="@Model.Id" 
                           class="btn btn-success btn-lg px-5 rounded-pill shadow">
                            Apply for this position
                        </a>

                        <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4 rounded-pill">
                            <i class="bi bi-arrow-left me-2"></i>Back to list
                        </a>

                       
                        @if (User.IsInRole("Admin") || (User.IsInRole("Employer") && Model.PublisherId == currentUserId))
                        {
                            <div class="ms-md-auto d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-lg rounded-pill px-4">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger btn-lg rounded-pill px-4">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>